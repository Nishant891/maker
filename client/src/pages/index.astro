---
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Maker</title>
    <style>
      :root {
        --bg:        #f3f3f1;
        --surface:   #ffffff;
        --ink:       #0a0a0a;
        --ink-muted: #6b6b6b;
        --rule:      #d8d8d6;
        --rule-strong: #0a0a0a;
        --accent:    #e63312;
        --grid: 8px;
        --font-sans: "Helvetica Neue", Helvetica, Inter, Arial, sans-serif;
        --font-mono: ui-monospace, "SF Mono", Menlo, monospace;
        color-scheme: light;
      }
      * { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; }
      body {
        font-family: var(--font-sans);
        font-size: 13px;
        line-height: 1.45;
        color: var(--ink);
        background: var(--bg);
        -webkit-font-smoothing: antialiased;
      }

      button, input, textarea, select {
        font-family: inherit;
        font-size: inherit;
        color: inherit;
      }
      button {
        border: 1px solid var(--ink);
        background: var(--surface);
        padding: 6px 12px;
        cursor: pointer;
        border-radius: 0;
        line-height: 1;
        letter-spacing: 0.02em;
      }
      button:hover { background: var(--ink); color: var(--surface); }
      button:disabled { opacity: 0.35; cursor: not-allowed; }
      button:disabled:hover { background: var(--surface); color: var(--ink); }
      button.primary { background: var(--ink); color: var(--surface); }
      button.primary:hover { background: var(--accent); border-color: var(--accent); }
      input[type="text"], textarea {
        border: 1px solid var(--ink);
        background: var(--surface);
        padding: 8px 10px;
        border-radius: 0;
        outline: 0;
      }
      input[type="text"]:focus, textarea:focus { border-color: var(--accent); }

      .app {
        display: grid;
        grid-template-columns: 30% 70%;
        height: 100vh;
        background: var(--bg);
      }
      .pane-left {
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border-right: 1px solid var(--rule-strong);
        min-width: 0;
      }
      .pane-right {
        position: relative;
        display: flex;
        flex-direction: column;
        min-width: 0;
        min-height: 0;
      }

      .left-header {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 12px;
        align-items: end;
        padding: 16px;
        border-bottom: 1px solid var(--rule-strong);
      }
      .brand {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--ink-muted);
      }
      .brand strong {
        display: block;
        font-size: 22px;
        font-weight: 700;
        letter-spacing: -0.01em;
        text-transform: none;
        color: var(--ink);
        margin-top: 4px;
      }
      .canvas-meta {
        font-size: 11px;
        text-align: right;
        color: var(--ink-muted);
        max-width: 100px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .canvas-meta .name {
        display: block;
        color: var(--ink);
        font-weight: 600;
        letter-spacing: 0.01em;
      }
      .canvas-meta button {
        margin-top: 6px;
        font-size: 11px;
        padding: 4px 8px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .tabs {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-bottom: 1px solid var(--rule-strong);
      }
      .tab {
        background: var(--surface);
        border: 0;
        border-right: 1px solid var(--rule);
        padding: 12px 0;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--ink-muted);
        cursor: pointer;
      }
      .tab:last-child { border-right: 0; }
      .tab:hover { color: var(--ink); background: var(--surface); }
      .tab.active {
        color: var(--ink);
        background: var(--surface);
        box-shadow: inset 0 -2px 0 var(--accent);
      }

      .tab-pane { display: none; flex: 1; min-height: 0; flex-direction: column; }
      .tab-pane.active { display: flex; }

      .chat-messages {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .msg {
        display: grid;
        grid-template-columns: 64px 1fr;
        gap: 12px;
        align-items: start;
      }
      .msg .role {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        color: var(--ink-muted);
        padding-top: 2px;
      }
      .msg.user .role { color: var(--accent); }
      .msg .body {
        white-space: pre-wrap;
        word-wrap: break-word;
        border-left: 1px solid var(--rule);
        padding-left: 12px;
      }
      .msg.user      .body { color: var(--ink); font-weight: 500; }
      .msg.assistant .body { color: #5a5a5a; }
      .chat-empty {
        padding: 24px 16px;
        color: var(--ink-muted);
        font-size: 12px;
      }

      .composer {
        border-top: 1px solid var(--rule-strong);
        padding: 12px;
        background: var(--surface);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 8px;
      }
      .composer textarea {
        min-height: 64px;
        max-height: 200px;
        resize: vertical;
        line-height: 1.4;
      }
      .composer .composer-side {
        display: flex;
        flex-direction: column;
        gap: 8px;
        justify-content: flex-end;
      }
      .composer select {
        border: 1px solid var(--ink);
        padding: 4px 8px;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        background: var(--surface);
        border-radius: 0;
      }
      .composer button {
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
        padding: 8px 14px;
      }

      .artifacts-list {
        flex: 1;
        overflow-y: auto;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .artifact-row {
        position: relative;
        display: flex;
        flex-direction: column;
        padding: 18px 18px 14px;
        background: var(--surface);
        border: 1px solid var(--ink);
        cursor: pointer;
        min-height: 132px;
        transition: background 0.12s ease;
      }
      .artifact-row:hover { background: #fafaf9; }
      .artifact-row .top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 14px;
      }
      .artifact-row .num {
        font-family: var(--font-mono);
        font-size: 12px;
        letter-spacing: 0.08em;
        color: var(--ink-muted);
      }
      .artifact-row .title {
        font-size: 17px;
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.25;
        color: var(--ink);
        flex: 1;
      }
      .artifact-row .foot {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 14px;
        padding-top: 10px;
        border-top: 1px solid var(--rule);
      }
      .artifact-row .dim {
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 0.04em;
        color: var(--ink-muted);
      }
      .artifact-row .kind {
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--ink-muted);
        margin-left: auto;
      }

      .artifact-row.active {
        border: 2px solid var(--accent);
        padding: 17px 17px 13px;
      }
      .artifact-row.active::after {
        content: '';
        position: absolute;
        top: 0; bottom: 0; left: -2px;
        width: 6px;
        background: var(--accent);
      }
      .artifact-row.active .num { color: var(--accent); }

      .artifact-row.generating { border-color: var(--accent); }
      .artifact-row.generating .num { color: var(--accent); }
      .artifact-row.placeholder {
        border-style: dashed;
        background: #fff7f5;
      }
      .artifact-row.placeholder .title { color: var(--ink-muted); font-style: italic; }
      .artifact-row.placeholder .dim   { color: var(--ink-muted); }

      .spinner {
        width: 12px;
        height: 12px;
        border: 2px solid var(--rule);
        border-top-color: var(--accent);
        border-radius: 50%;
        animation: spin 0.8s linear infinite;
        flex-shrink: 0;
      }
      .gen-tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 10px;
        text-transform: uppercase;
        letter-spacing: 0.18em;
        color: var(--accent);
      }
      @keyframes spin { to { transform: rotate(360deg); } }

      .artifacts-empty {
        padding: 24px 8px;
        color: var(--ink-muted);
        font-size: 12px;
        text-align: center;
      }

      .canvas-header {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 16px;
        align-items: center;
        padding: 12px 24px;
        border-bottom: 1px solid var(--rule-strong);
        background: var(--surface);
      }
      .canvas-header .title {
        font-size: 16px;
        font-weight: 700;
        letter-spacing: -0.01em;
      }
      .canvas-header .title span.dim {
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--ink-muted);
        margin-left: 12px;
        font-weight: 400;
      }
      .toolbar {
        display: inline-flex;
        gap: 4px;
        align-items: center;
      }
      .toolbar button {
        padding: 6px 10px;
        font-size: 12px;
        min-width: 32px;
      }
      .toolbar button.active {
        background: var(--accent);
        color: var(--surface);
        border-color: var(--accent);
      }
      .toolbar .sep {
        width: 1px;
        height: 18px;
        background: var(--rule);
        margin: 0 4px;
      }
      .toolbar input[type="color"] {
        width: 30px; height: 30px;
        border: 1px solid var(--ink);
        background: var(--surface);
        padding: 2px;
        cursor: pointer;
      }

      .zoom {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-mono);
        font-size: 11px;
        color: var(--ink-muted);
      }
      .zoom button { padding: 4px 8px; min-width: 28px; }
      .zoom .pct { min-width: 48px; text-align: center; color: var(--ink); }

      .viewport {
        flex: 1;
        position: relative;
        overflow: hidden;
        background:
          linear-gradient(to right,  var(--rule) 1px, transparent 1px) 0 0 / 48px 48px,
          linear-gradient(to bottom, var(--rule) 1px, transparent 1px) 0 0 / 48px 48px,
          var(--bg);
      }
      .stage-wrap {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: auto;
      }
      .stage {
        position: relative;
        background: #fff;
        box-shadow:
          0  1px 0 rgba(0,0,0,0.04),
          0 12px 32px rgba(0,0,0,0.10);
        transform-origin: center center;
        /* width/height/transform set inline from JS */
      }
      .stage iframe {
        width: 100%;
        height: 100%;
        border: 0;
        background: #fff;
      }
      .viewport-empty {
        position: absolute;
        inset: 0;
        display: grid;
        place-items: center;
        color: var(--ink-muted);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.16em;
      }

      .stream-dot {
        display: inline-block;
        width: 6px; height: 6px;
        background: var(--accent);
        margin-left: 6px;
        animation: pulse 1.1s ease-in-out infinite;
        vertical-align: middle;
      }
      @keyframes pulse {
        0%, 100% { opacity: 0.25; }
        50%      { opacity: 1; }
      }

      .msg.status .role {
        color: var(--accent);
        font-size: 14px;
        line-height: 1;
        animation: pulse 1.1s ease-in-out infinite;
      }
      .msg.status .body {
        color: var(--ink-muted);
        font-style: italic;
      }

      .pane-right.locked .stage iframe { pointer-events: none; }
      .pane-right.locked .stage         { opacity: 0.65; transition: opacity 0.2s; }
      .pane-right.locked .toolbar       { opacity: 0.4; pointer-events: none; }

      .modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(10, 10, 10, 0.4);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 100;
      }
      .modal-backdrop.open { display: flex; }
      .modal {
        background: var(--surface);
        border: 1px solid var(--ink);
        width: min(560px, 92vw);
        padding: 32px;
        display: grid;
        gap: 16px;
      }
      .modal h2 {
        margin: 0;
        font-size: 36px;
        letter-spacing: -0.02em;
        line-height: 1;
      }
      .modal .modal-sub {
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--ink-muted);
        border-bottom: 1px solid var(--ink);
        padding-bottom: 8px;
      }
      .modal label {
        display: grid;
        gap: 6px;
      }
      .modal label .label-text {
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--ink-muted);
      }
      .modal .help {
        font-size: 11px;
        color: var(--ink-muted);
        line-height: 1.5;
      }
      .modal .actions {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        margin-top: 8px;
      }
      .modal .actions button {
        text-transform: uppercase;
        letter-spacing: 0.16em;
        font-size: 11px;
        padding: 10px 18px;
      }

      ::-webkit-scrollbar { width: 8px; height: 8px; }
      ::-webkit-scrollbar-thumb { background: var(--rule-strong); }
      ::-webkit-scrollbar-track { background: transparent; }
    </style>
  </head>

  <body>
    <div class="app">
      <aside class="pane-left">
        <div class="left-header">
          <div class="brand">
            Maker
            <strong id="canvasName">Untitled</strong>
          </div>
          <div class="canvas-meta">
            <span class="name" id="canvasDir">no canvas</span>
            <button id="btnSwitchCanvas" type="button">Switch</button>
          </div>
        </div>

        <nav class="tabs" role="tablist">
          <button class="tab active" data-tab="chat" role="tab">Chat</button>
          <button class="tab" data-tab="artifacts" role="tab">Artifacts</button>
        </nav>

        <section class="tab-pane active" id="tab-chat" role="tabpanel">
          <div class="chat-messages" id="chatMessages">
            <div class="chat-empty">No messages yet. Describe an artifact to generate.</div>
          </div>
          <div class="composer">
            <textarea
              id="prompt"
              placeholder="Make a slide titled 'Q3 launch' with three bullets…"
              rows="3"
            ></textarea>
            <div class="composer-side">
              <select id="providerSel" title="agent provider"></select>
              <button id="btnSend" class="primary" type="button">Send</button>
            </div>
          </div>
        </section>

        <section class="tab-pane" id="tab-artifacts" role="tabpanel">
          <div class="artifacts-list" id="artifactsList">
            <div class="artifacts-empty">No artifacts yet.</div>
          </div>
        </section>
      </aside>

      <main class="pane-right">
        <header class="canvas-header">
          <div class="title" id="artifactTitle">
            No artifact selected
            <span class="dim" id="artifactDim"></span>
          </div>

          <div class="toolbar" id="toolbar">
            <button data-cmd="bold"   title="Bold"><b>B</b></button>
            <button data-cmd="italic" title="Italic"><i>I</i></button>
            <span class="sep"></span>
            <input type="color" id="colorPicker" value="#000000" title="Color" />
            <span class="sep"></span>
            <button data-cmd="left"   title="Align left">⟸</button>
            <button data-cmd="center" title="Align center">≡</button>
            <button data-cmd="right"  title="Align right">⟹</button>
          </div>

          <div class="zoom">
            <button id="zoomOut" title="Zoom out">−</button>
            <span class="pct" id="zoomPct">100%</span>
            <button id="zoomReset" title="Reset zoom (fit)">FIT</button>
            <button id="zoomIn" title="Zoom in">+</button>
          </div>
        </header>

        <div class="viewport" id="viewport">
          <div class="viewport-empty" id="viewportEmpty">Pick or generate an artifact</div>
          <div class="stage-wrap">
            <div class="stage" id="stage" style="display:none">
              <iframe id="preview" title="artifact preview"></iframe>
            </div>
          </div>
        </div>
      </main>
    </div>

    <div class="modal-backdrop" id="canvasModal">
      <div class="modal">
        <div class="modal-sub">New canvas</div>
        <h2>Pick a folder.</h2>
        <p class="help">
          A canvas is a real directory on your disk. Drop images and docs inside
          it for the agent to use as context. Artifacts are written to an
          <code>artifacts/</code> subfolder.
        </p>
        <label>
          <span class="label-text">Canvas name</span>
          <input type="text" id="modalName" placeholder="My Deck" />
        </label>
        <label>
          <span class="label-text">Canvas root (absolute path)</span>
          <input
            type="text"
            id="modalDir"
            placeholder="/Users/you/Desktop/my-deck"
            spellcheck="false"
          />
          <span class="help">
            The browser can't pick server directories, so type or paste the path.
            The folder must exist and be writable.
          </span>
        </label>
        <div id="modalError" class="help" style="color: var(--accent); display: none;"></div>
        <div class="actions">
          <button id="modalCancel" type="button">Cancel</button>
          <button id="modalCreate" class="primary" type="button">Create canvas</button>
        </div>
      </div>
    </div>

    <script is:inline>
      const SERVER  = 'http://localhost:5174';
      const LS_KEY  = 'maker.canvas.v1';

      const $canvasName   = document.getElementById('canvasName');
      const $canvasDir    = document.getElementById('canvasDir');
      const $btnSwitch    = document.getElementById('btnSwitchCanvas');
      const $tabs         = document.querySelectorAll('.tab');
      const $tabPanes     = document.querySelectorAll('.tab-pane');
      const $chatMsgs     = document.getElementById('chatMessages');
      const $prompt       = document.getElementById('prompt');
      const $providerSel  = document.getElementById('providerSel');
      const $btnSend      = document.getElementById('btnSend');
      const $artifacts    = document.getElementById('artifactsList');
      const $artTitle     = document.getElementById('artifactTitle');
      const $artDim       = document.getElementById('artifactDim');
      const $viewport     = document.getElementById('viewport');
      const $viewEmpty    = document.getElementById('viewportEmpty');
      const $stage        = document.getElementById('stage');
      const $iframe       = document.getElementById('preview');
      const $toolbar      = document.getElementById('toolbar');
      const $color        = document.getElementById('colorPicker');
      const $zoomIn       = document.getElementById('zoomIn');
      const $zoomOut      = document.getElementById('zoomOut');
      const $zoomReset    = document.getElementById('zoomReset');
      const $zoomPct      = document.getElementById('zoomPct');
      const $modal        = document.getElementById('canvasModal');
      const $modalName    = document.getElementById('modalName');
      const $modalDir     = document.getElementById('modalDir');
      const $modalCreate  = document.getElementById('modalCreate');
      const $modalCancel  = document.getElementById('modalCancel');
      const $modalError   = document.getElementById('modalError');

      const state = {
        canvas: null,
        manifest: null,
        files: [],
        activeArtifactId: null,
        zoom: 'fit',
        streaming: false,
        streamingMsgEl: null,
        generatingFile: null,
        generatingTitle: null,
        providers: [],
      };
      const $paneRight = document.querySelector('.pane-right');

      const EDITOR_CSS = `
        .selected { outline: 2px solid #e63312 !important; outline-offset: 1px; }
        .resize-handle {
          position: absolute; width: 10px; height: 10px;
          background: #e63312; border: 1px solid #fff;
          z-index: 999999; box-sizing: border-box;
        }
        .resize-handle.nw { cursor: nwse-resize; }
        .resize-handle.n  { cursor: ns-resize; }
        .resize-handle.ne { cursor: nesw-resize; }
        .resize-handle.e  { cursor: ew-resize; }
        .resize-handle.se { cursor: nwse-resize; }
        .resize-handle.s  { cursor: ns-resize; }
        .resize-handle.sw { cursor: nesw-resize; }
        .resize-handle.w  { cursor: ew-resize; }
        .e-bold   { font-weight: bold; }
        .e-italic { font-style: italic; }
        body * { cursor: default; }
      `;

      const EDITOR_JS = `
        (function () {
          const doc = document;

          let selected = null;
          let editing  = null;
          let zCounter = 1;
          const handles = [];
          const HANDLE_DIRS = ['nw','n','ne','e','se','s','sw','w'];

          function exitEditing() {
            if (!editing) return;
            editing.setAttribute('contenteditable', 'false');
            try { editing.blur(); } catch (_) {}
            editing = null;
          }

          function isEditorChrome(el) {
            return el && el.classList && el.classList.contains('resize-handle');
          }

          function ensureAbsolute(el) {
            const cs = getComputedStyle(el);
            if (cs.position === 'static' || !el.style.left || !el.style.top) {
              const oLeft   = el.offsetLeft;
              const oTop    = el.offsetTop;
              const oWidth  = el.offsetWidth;
              const oHeight = el.offsetHeight;

              const absDescendants = [];
              el.querySelectorAll('*').forEach(d => {
                if (getComputedStyle(d).position === 'absolute') {
                  absDescendants.push({ node: d, rect: d.getBoundingClientRect() });
                }
              });

              if (el.parentNode && !el.__ghost) {
                const ghost = doc.createElement('div');
                ghost.className = 'edit-ghost';
                ghost.style.display       = cs.display;
                ghost.style.margin        = cs.margin;
                ghost.style.flex          = cs.flex;
                ghost.style.verticalAlign = cs.verticalAlign;
                ghost.style.width         = oWidth  + 'px';
                ghost.style.height        = oHeight + 'px';
                ghost.style.visibility    = 'hidden';
                el.parentNode.insertBefore(ghost, el);
                el.__ghost = ghost;
              }

              el.style.position = 'absolute';
              el.style.margin   = '0';
              el.style.left   = oLeft   + 'px';
              el.style.top    = oTop    + 'px';
              el.style.width  = oWidth  + 'px';
              el.style.height = oHeight + 'px';

              if (absDescendants.length) {
                const elRect = el.getBoundingClientRect();
                const ecs = getComputedStyle(el);
                const elBorderLeft = parseFloat(ecs.borderLeftWidth) || 0;
                const elBorderTop  = parseFloat(ecs.borderTopWidth)  || 0;
                absDescendants.forEach(({ node, rect }) => {
                  node.style.left = (rect.left - elRect.left - elBorderLeft) + 'px';
                  node.style.top  = (rect.top  - elRect.top  - elBorderTop)  + 'px';
                });
              }
            }
          }

          function notifyParentSelection() {
            try { parent.__editorOnSelectionChange && parent.__editorOnSelectionChange(); } catch (e) {}
          }

          function clearHandles() {
            handles.forEach(h => h.remove());
            handles.length = 0;
          }

          function placeHandles() {
            clearHandles();
            if (!selected) return;
            const rect = selected.getBoundingClientRect();
            const left = rect.left + window.scrollX;
            const top  = rect.top  + window.scrollY;
            const w = rect.width, h = rect.height;
            const positions = {
              nw: [left,         top],
              n:  [left + w / 2, top],
              ne: [left + w,     top],
              e:  [left + w,     top + h / 2],
              se: [left + w,     top + h],
              s:  [left + w / 2, top + h],
              sw: [left,         top + h],
              w:  [left,         top + h / 2],
            };
            HANDLE_DIRS.forEach(dir => {
              const handle = doc.createElement('div');
              handle.className = 'resize-handle ' + dir;
              handle.dataset.dir = dir;
              const [x, y] = positions[dir];
              handle.style.left = (x - 5) + 'px';
              handle.style.top  = (y - 5) + 'px';
              handle.addEventListener('pointerdown', onResizeDown);
              doc.body.appendChild(handle);
              handles.push(handle);
            });
          }

          function select(el) {
            if (editing && editing !== el) exitEditing();
            if (selected === el) return;
            if (selected) selected.classList.remove('selected');
            selected = el;
            if (selected) {
              selected.classList.add('selected');
              zCounter += 1;
              selected.style.zIndex = String(zCounter);
              placeHandles();
            } else {
              clearHandles();
            }
            notifyParentSelection();
          }

          doc.addEventListener('click', function (e) {
            if (editing && e.target !== editing && !editing.contains(e.target)) {
              exitEditing();
            }
            if (e.target.tagName === 'A' || e.target.tagName === 'BUTTON') {
              e.preventDefault();
            }
            if (isEditorChrome(e.target)) return;
            if (e.target === doc.documentElement || e.target === doc.body) {
              select(null);
              return;
            }
            select(e.target);
          }, true);

          const DRAG_THRESHOLD = 3;
          let drag = null;
          doc.addEventListener('pointerdown', function (e) {
            if (isEditorChrome(e.target)) return;
            if (e.target === doc.documentElement || e.target === doc.body) return;
            const target = e.target;
            if (target.isContentEditable) return;
            select(target);
            drag = {
              el: target,
              startX: e.clientX, startY: e.clientY,
              startLeft: 0, startTop: 0,
              lifted: false,
            };
            try { target.setPointerCapture(e.pointerId); } catch (_) {}
            e.preventDefault();
          });

          doc.addEventListener('pointermove', function (e) {
            if (!drag) return;
            const dx = e.clientX - drag.startX;
            const dy = e.clientY - drag.startY;
            if (!drag.lifted) {
              if (Math.abs(dx) <= DRAG_THRESHOLD && Math.abs(dy) <= DRAG_THRESHOLD) return;
              ensureAbsolute(drag.el);
              drag.startLeft = parseFloat(drag.el.style.left) || 0;
              drag.startTop  = parseFloat(drag.el.style.top)  || 0;
              drag.lifted = true;
            }
            drag.el.style.left = (drag.startLeft + dx) + 'px';
            drag.el.style.top  = (drag.startTop  + dy) + 'px';
            placeHandles();
          });

          doc.addEventListener('pointerup', function () { drag = null; });

          let resize = null;
          function onResizeDown(e) {
            if (!selected) return;
            e.stopPropagation();
            e.preventDefault();
            ensureAbsolute(selected);
            const dir = e.currentTarget.dataset.dir;
            resize = {
              dir, el: selected,
              startX: e.clientX, startY: e.clientY,
              startLeft:  parseFloat(selected.style.left) || 0,
              startTop:   parseFloat(selected.style.top)  || 0,
              startWidth:  selected.getBoundingClientRect().width,
              startHeight: selected.getBoundingClientRect().height,
            };
            try { e.currentTarget.setPointerCapture(e.pointerId); } catch (_) {}
          }

          doc.addEventListener('pointermove', function (e) {
            if (!resize) return;
            const dx = e.clientX - resize.startX;
            const dy = e.clientY - resize.startY;
            let { startLeft, startTop, startWidth, startHeight, dir, el } = resize;
            let newLeft = startLeft, newTop = startTop;
            let newW = startWidth, newH = startHeight;
            if (dir.includes('e')) newW = startWidth + dx;
            if (dir.includes('s')) newH = startHeight + dy;
            if (dir.includes('w')) { newW = startWidth - dx; newLeft = startLeft + dx; }
            if (dir.includes('n')) { newH = startHeight - dy; newTop  = startTop  + dy; }
            const MIN = 8;
            if (newW < MIN) {
              if (dir.includes('w')) newLeft = startLeft + (startWidth - MIN);
              newW = MIN;
            }
            if (newH < MIN) {
              if (dir.includes('n')) newTop = startTop + (startHeight - MIN);
              newH = MIN;
            }
            el.style.left   = newLeft + 'px';
            el.style.top    = newTop  + 'px';
            el.style.width  = newW + 'px';
            el.style.height = newH + 'px';
            placeHandles();
          });

          doc.addEventListener('pointerup', function () { resize = null; });

          doc.addEventListener('dblclick', function (e) {
            if (isEditorChrome(e.target)) return;
            if (e.target === doc.documentElement || e.target === doc.body) return;
            const el = e.target;
            el.setAttribute('contenteditable', 'true');
            el.focus();
            editing = el;
            const range = doc.createRange();
            range.selectNodeContents(el);
            range.collapse(false);
            const sel = window.getSelection();
            sel.removeAllRanges();
            sel.addRange(range);
          });

          doc.addEventListener('blur', function (e) {
            if (e.target && e.target.getAttribute && e.target.getAttribute('contenteditable') === 'true') {
              e.target.setAttribute('contenteditable', 'false');
            }
          }, true);

          window.addEventListener('scroll', placeHandles, true);
          window.addEventListener('resize', placeHandles);

          window.__editor = {
            getSelected: () => selected,
            toggleClass: function (cls) {
              if (!selected) return;
              selected.classList.toggle(cls);
              notifyParentSelection();
            },
            setColor: function (color) {
              if (!selected) return;
              selected.style.color = color;
              notifyParentSelection();
            },
            setAlign: function (align) {
              if (!selected) return;
              selected.style.textAlign = align;
              notifyParentSelection();
            },
            exportClean: function () {
              clearHandles();
              const wasSelected = selected;
              if (wasSelected) wasSelected.classList.remove('selected');
              const clone = doc.documentElement.cloneNode(true);
              clone.querySelectorAll('.resize-handle, .edit-ghost, #__editor_css, #__editor_js').forEach(n => n.remove());
              clone.querySelectorAll('.selected').forEach(n => n.classList.remove('selected'));
              const html = '<!doctype html>\\n' + clone.outerHTML;
              if (wasSelected) {
                wasSelected.classList.add('selected');
                placeHandles();
              }
              return html;
            },
          };
        })();
      `;

      function buildSrcdoc(rawHtml) {
        const inject =
          '<style id="__editor_css">' + EDITOR_CSS + '</style>' +
          '<script id="__editor_js">' + EDITOR_JS + '<\/script>';
        if (/<\/body>/i.test(rawHtml)) {
          return rawHtml.replace(/<\/body>/i, inject + '</body>');
        }
        return rawHtml + inject;
      }

      function loadStoredCanvas() {
        try {
          const raw = localStorage.getItem(LS_KEY);
          return raw ? JSON.parse(raw) : null;
        } catch (_) { return null; }
      }
      function storeCanvas(c) { localStorage.setItem(LS_KEY, JSON.stringify(c)); }

      function openModal() {
        $modalError.style.display = 'none';
        $modalError.textContent = '';
        if (state.canvas) {
          $modalName.value = state.canvas.name || '';
          $modalDir.value  = state.canvas.dir  || '';
        }
        $modal.classList.add('open');
        setTimeout(() => $modalName.focus(), 30);
      }
      function closeModal() { $modal.classList.remove('open'); }

      $btnSwitch.addEventListener('click', () => openModal());
      $modalCancel.addEventListener('click', () => {
        if (state.canvas) closeModal();
      });
      $modalCreate.addEventListener('click', async () => {
        const name = $modalName.value.trim() || 'Untitled';
        const dir  = $modalDir.value.trim();
        if (!dir) {
          showModalError('Canvas root is required.');
          return;
        }
        try {
          const res = await fetch(SERVER + '/api/canvas', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, dir }),
          });
          const data = await res.json();
          if (!res.ok) {
            showModalError(data.error || 'Failed to create canvas.');
            return;
          }
          state.canvas = { name: data.manifest.name || name, dir: data.dir };
          storeCanvas(state.canvas);
          applyManifest(data);
          closeModal();
          await refreshCanvas();
        } catch (e) {
          showModalError('Server unreachable at ' + SERVER + ' — is it running?');
        }
      });
      function showModalError(msg) {
        $modalError.textContent = msg;
        $modalError.style.display = 'block';
      }

      async function fetchProviders() {
        try {
          const res = await fetch(SERVER + '/api/providers');
          const list = await res.json();
          state.providers = Array.isArray(list) ? list : [];
        } catch (_) {
          state.providers = [];
        }
        renderProviders();
      }
      function renderProviders() {
        $providerSel.innerHTML = '';
        if (!state.providers.length) {
          const opt = document.createElement('option');
          opt.textContent = 'No agents found';
          opt.disabled = true;
          $providerSel.appendChild(opt);
          return;
        }
        for (const p of state.providers) {
          const opt = document.createElement('option');
          opt.value = p.name;
          opt.textContent = p.name;
          if (p.name === 'ollama') opt.disabled = true;
          $providerSel.appendChild(opt);
        }
      }

      async function refreshCanvas() {
        if (!state.canvas) return;
        try {
          const res = await fetch(
            SERVER + '/api/canvas?dir=' + encodeURIComponent(state.canvas.dir)
          );
          if (!res.ok) return;
          const data = await res.json();
          applyManifest(data);
        } catch (_) {}
      }

      function applyManifest(data) {
        state.manifest = data.manifest;
        state.files    = data.files || [];
        $canvasName.textContent = (state.manifest && state.manifest.name) || state.canvas.name;
        $canvasDir.textContent  = state.canvas.dir;
        renderMessages();
        renderArtifacts();
      }

      $tabs.forEach(t => t.addEventListener('click', () => switchTab(t.dataset.tab)));
      function switchTab(name) {
        $tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === name));
        $tabPanes.forEach(p => p.classList.toggle('active', p.id === 'tab-' + name));
      }

      function renderMessages() {
        $chatMsgs.innerHTML = '';
        const msgs = state.manifest && state.manifest.messages || [];
        if (!msgs.length) {
          const empty = document.createElement('div');
          empty.className = 'chat-empty';
          empty.textContent = 'No messages yet. Describe an artifact to generate.';
          $chatMsgs.appendChild(empty);
          return;
        }
        for (const m of msgs) $chatMsgs.appendChild(messageEl(m.role, m.content));
        $chatMsgs.scrollTop = $chatMsgs.scrollHeight;
      }
      function messageEl(role, content) {
        const wrap = document.createElement('div');
        wrap.className = 'msg ' + role;
        const r = document.createElement('div');
        r.className = 'role';
        r.textContent = role === 'user' ? 'You' : 'Agent';
        const b = document.createElement('div');
        b.className = 'body';
        b.textContent = content;
        wrap.appendChild(r);
        wrap.appendChild(b);
        return wrap;
      }

      function kindFromDims(w, h) {
        if (w === 1280 && h === 720)  return 'Slide';
        if (w === 794  && h === 1123) return 'A4';
        if (w === 1080 && h === 1080) return 'Card';
        if (w === 1440 && h === 900)  return 'Web';
        return 'Custom';
      }

      function buildArtifactCard(opts) {
        const row = document.createElement('div');
        row.className = 'artifact-row' + (opts.classes || '');
        const generating = !!opts.generating;
        row.innerHTML =
          '<div class="top">' +
            '<div class="num"></div>' +
            (generating
              ? '<div class="gen-tag"><span class="spinner"></span>Generating</div>'
              : '') +
          '</div>' +
          '<div class="title"></div>' +
          '<div class="foot">' +
            '<div class="dim"></div>' +
            '<div class="kind"></div>' +
          '</div>';
        row.querySelector('.num').textContent   = opts.num;
        row.querySelector('.title').textContent = opts.title;
        row.querySelector('.dim').textContent   = opts.dim;
        row.querySelector('.kind').textContent  = opts.kind;
        if (opts.onClick) row.addEventListener('click', opts.onClick);
        return row;
      }

      function renderArtifacts() {
        $artifacts.innerHTML = '';
        const list = (state.manifest && state.manifest.artifacts) || [];
        const gen  = state.generatingFile;
        const generatingInList = !!(gen && list.some(a => a.file === gen));

        if (!list.length && !gen) {
          const e = document.createElement('div');
          e.className = 'artifacts-empty';
          e.textContent = 'No artifacts yet.';
          $artifacts.appendChild(e);
          return;
        }

        list.forEach((a, i) => {
          let classes = '';
          if (a.id === state.activeArtifactId) classes += ' active';
          if (gen === a.file) classes += ' generating';
          $artifacts.appendChild(buildArtifactCard({
            classes,
            generating: gen === a.file,
            num:   String(i + 1).padStart(2, '0'),
            title: a.title || a.id,
            dim:   a.width + ' × ' + a.height,
            kind:  kindFromDims(a.width, a.height),
            onClick: () => loadArtifact(a.id),
          }));
        });

        // Placeholder card while the agent is writing a brand-new file that
        // hasn't been registered in the manifest yet.
        if (gen && !generatingInList) {
          $artifacts.appendChild(buildArtifactCard({
            classes: ' placeholder generating',
            generating: true,
            num:   String(list.length + 1).padStart(2, '0'),
            title: state.generatingTitle || 'New artifact',
            dim:   '— × —',
            kind:  '',
          }));
        }
      }

      async function loadArtifact(id) {
        if (!state.canvas || !state.manifest) return;
        const a = state.manifest.artifacts.find(x => x.id === id);
        if (!a) return;
        state.activeArtifactId = id;
        $artTitle.firstChild.textContent = a.title || a.id;
        $artDim.textContent = a.width + ' × ' + a.height;
        $viewEmpty.style.display = 'none';
        $stage.style.display = 'block';
        $stage.style.width  = a.width  + 'px';
        $stage.style.height = a.height + 'px';
        applyZoom();
        renderArtifacts();
        try {
          const res = await fetch(
            SERVER + '/api/file?dir=' + encodeURIComponent(state.canvas.dir) +
            '&file=' + encodeURIComponent(a.file)
          );
          const html = await res.text();
          $iframe.srcdoc = buildSrcdoc(html);
        } catch (e) {
          console.error('[maker] artifact fetch failed', e);
        }
      }

      function applyZoom() {
        if (!state.activeArtifactId || !state.manifest) {
          $zoomPct.textContent = '—';
          return;
        }
        const a = state.manifest.artifacts.find(x => x.id === state.activeArtifactId);
        if (!a) return;
        const PADDING = 48;
        const availW = $viewport.clientWidth  - PADDING * 2;
        const availH = $viewport.clientHeight - PADDING * 2;
        let scale;
        if (state.zoom === 'fit') {
          scale = Math.min(availW / a.width, availH / a.height);
          if (!isFinite(scale) || scale <= 0) scale = 1;
        } else {
          scale = state.zoom;
        }
        $stage.style.transform = 'scale(' + scale + ')';
        $zoomPct.textContent = Math.round(scale * 100) + '%';
      }
      $zoomIn.addEventListener('click', () => {
        const cur = currentZoomValue();
        state.zoom = Math.min(cur * 1.2, 4);
        applyZoom();
      });
      $zoomOut.addEventListener('click', () => {
        const cur = currentZoomValue();
        state.zoom = Math.max(cur / 1.2, 0.05);
        applyZoom();
      });
      $zoomReset.addEventListener('click', () => {
        state.zoom = 'fit';
        applyZoom();
      });
      function currentZoomValue() {
        if (state.zoom !== 'fit') return state.zoom;
        const a = state.manifest && state.manifest.artifacts.find(x => x.id === state.activeArtifactId);
        if (!a) return 1;
        const PADDING = 48;
        const availW = $viewport.clientWidth  - PADDING * 2;
        const availH = $viewport.clientHeight - PADDING * 2;
        return Math.min(availW / a.width, availH / a.height) || 1;
      }
      window.addEventListener('resize', () => {
        if (state.zoom === 'fit') applyZoom();
      });

      $toolbar.addEventListener('click', (e) => {
        const btn = e.target.closest('button');
        if (!btn) return;
        const cmd = btn.dataset.cmd;
        const ed = $iframe.contentWindow && $iframe.contentWindow.__editor;
        if (!ed) return;
        if (cmd === 'bold')   ed.toggleClass('e-bold');
        if (cmd === 'italic') ed.toggleClass('e-italic');
        if (cmd === 'left' || cmd === 'center' || cmd === 'right') ed.setAlign(cmd);
        refreshToolbar();
      });
      $color.addEventListener('input', () => {
        const ed = $iframe.contentWindow && $iframe.contentWindow.__editor;
        if (ed) ed.setColor($color.value);
      });
      function refreshToolbar() {
        const ed = $iframe.contentWindow && $iframe.contentWindow.__editor;
        const sel = ed && ed.getSelected();
        const buttons = $toolbar.querySelectorAll('button[data-cmd]');
        buttons.forEach(b => b.classList.remove('active'));
        if (!sel) return;
        if (sel.classList.contains('e-bold'))   $toolbar.querySelector('[data-cmd="bold"]').classList.add('active');
        if (sel.classList.contains('e-italic')) $toolbar.querySelector('[data-cmd="italic"]').classList.add('active');
        const align = sel.style.textAlign;
        if (align === 'left')   $toolbar.querySelector('[data-cmd="left"]').classList.add('active');
        if (align === 'center') $toolbar.querySelector('[data-cmd="center"]').classList.add('active');
        if (align === 'right')  $toolbar.querySelector('[data-cmd="right"]').classList.add('active');
        if (sel.style.color) {
          const hex = rgbToHex(sel.style.color);
          if (hex) $color.value = hex;
        }
      }
      window.__editorOnSelectionChange = refreshToolbar;
      function rgbToHex(s) {
        const m = /rgb\((\d+)\s*,\s*(\d+)\s*,\s*(\d+)\)/.exec(s);
        if (!m) return null;
        const toHex = n => Number(n).toString(16).padStart(2, '0');
        return '#' + toHex(m[1]) + toHex(m[2]) + toHex(m[3]);
      }

      $btnSend.addEventListener('click', send);
      $prompt.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
          e.preventDefault();
          send();
        }
      });

      async function send() {
        if (state.streaming) return;
        if (!state.canvas) { openModal(); return; }
        const prompt = $prompt.value.trim();
        if (!prompt) return;
        const provider = $providerSel.value;
        if (!provider) { alert('No agent provider available.'); return; }

        $chatMsgs.querySelector('.chat-empty')?.remove();
        $chatMsgs.appendChild(messageEl('user', prompt));
        $prompt.value = '';
        $chatMsgs.scrollTop = $chatMsgs.scrollHeight;

        const assistantEl = messageEl('assistant', '');
        assistantEl.querySelector('.role').innerHTML = 'Agent <span class="stream-dot"></span>';
        $chatMsgs.appendChild(assistantEl);
        $chatMsgs.scrollTop = $chatMsgs.scrollHeight;

        state.streaming = true;
        state.streamingMsgEl = assistantEl;
        $btnSend.disabled = true;
        $paneRight.classList.add('locked');

        try {
          await streamGenerate({ dir: state.canvas.dir, provider, prompt });
        } catch (e) {
          console.error('[maker] stream error:', e);
        } finally {
          state.streaming = false;
          state.streamingMsgEl = null;
          state.generatingFile = null;
          state.generatingTitle = null;
          $btnSend.disabled = false;
          $paneRight.classList.remove('locked');
          clearWorkingStatus();
          // Stop the assistant bubble's pulsing dot.
          assistantEl.querySelector('.role').textContent = 'Agent';
          const body = assistantEl.querySelector('.body');
          if (!body.textContent) body.textContent = '(no reply)';
          await refreshCanvas();
          renderArtifacts();
        }
      }

      // EventSource is GET-only, so we read the response body as a stream and
      // demux the SSE wire format ourselves.
      async function streamGenerate(body) {
        const res = await fetch(SERVER + '/api/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(body),
        });
        if (!res.ok) {
          const t = await res.text();
          throw new Error(t || ('HTTP ' + res.status));
        }
        const reader = res.body.getReader();
        const decoder = new TextDecoder();
        let buf = '';
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buf += decoder.decode(value, { stream: true });
          let idx;
          while ((idx = buf.indexOf('\n\n')) !== -1) {
            const frame = buf.slice(0, idx);
            buf = buf.slice(idx + 2);
            handleSSEFrame(frame);
          }
        }
      }

      function setWorkingStatus(label) {
        let el = $chatMsgs.querySelector('.msg.status');
        if (!el) {
          el = document.createElement('div');
          el.className = 'msg status';
          el.innerHTML = '<div class="role">●</div><div class="body"></div>';
          $chatMsgs.appendChild(el);
        }
        el.querySelector('.body').textContent = label;
        $chatMsgs.scrollTop = $chatMsgs.scrollHeight;
      }
      function clearWorkingStatus() {
        const el = $chatMsgs.querySelector('.msg.status');
        if (el) el.remove();
      }

      function handleSSEFrame(frame) {
        let event = 'message';
        const dataLines = [];
        for (const line of frame.split('\n')) {
          if (line.startsWith('event:')) event = line.slice(6).trim();
          else if (line.startsWith('data:'))  dataLines.push(line.slice(5).replace(/^ /, ''));
        }
        const data = dataLines.join('\n');

        if (event === 'text') {
          if (state.streamingMsgEl) {
            state.streamingMsgEl.querySelector('.body').textContent += data;
            $chatMsgs.scrollTop = $chatMsgs.scrollHeight;
          }
          return;
        }

        if (event === 'working') {
          try {
            const p = JSON.parse(data);
            state.generatingFile  = p.file  || null;
            state.generatingTitle = p.title || p.file || 'artifact';
            setWorkingStatus('Generating ' + state.generatingTitle + '…');
            renderArtifacts();
          } catch (_) {}
          return;
        }

        if (event === 'artifact') {
          try {
            const a = JSON.parse(data);
            if (!state.manifest) state.manifest = { name: '', messages: [], artifacts: [] };
            const list = state.manifest.artifacts;
            const ix = list.findIndex(x => x.id === a.id || x.file === a.file);
            if (ix >= 0) list[ix] = a; else list.push(a);
            renderArtifacts();
            switchTab('artifacts');
            loadArtifact(a.id);
          } catch (e) {
            console.warn('[maker] bad artifact payload', e);
          }
          return;
        }

        if (event === 'canvas') {
          try {
            applyManifest(JSON.parse(data));
          } catch (e) {
            console.warn('[maker] bad canvas payload', e);
          }
          return;
        }

        if (event === 'error') {
          console.error('[maker] server error event:', data);
          return;
        }
      }

      (async function init() {
        fetchProviders();
        const stored = loadStoredCanvas();
        if (stored && stored.dir) {
          state.canvas = stored;
          $canvasName.textContent = stored.name || 'Untitled';
          $canvasDir.textContent  = stored.dir;
          await refreshCanvas();
          const list = (state.manifest && state.manifest.artifacts) || [];
          if (list.length) loadArtifact(list[0].id);
        } else {
          openModal();
        }
      })();
    </script>
  </body>
</html>
